# --- LLM ---
# LangChain model id. Examples:
#   Ollama (local):  ollama:qwen2.5:7b
#   Google Gemini:   google_genai:gemini-2.0-flash
MODEL=ollama:qwen2.5:7b

# Ollama (only when MODEL starts with ollama:)
OLLAMA_HOST=http://127.0.0.1:11434

# Google Gemini free tier — get a key at https://aistudio.google.com/apikey
# (only when MODEL starts with google_genai:)
# GOOGLE_API_KEY=

# --- Jira ---
JIRA_DOMAIN=your-domain
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# Exact Jira workflow status names (column names may differ from status names)
IN_REVIEW_COLUMN_STATUS="UNDER AGENT REVIEW"
DEFER_COLUMN_STATUS="NEEDS MANUAL REVIEW"
RESOLVED_COLUMN_STATUS=RESOLVED

# Optional: HMAC secret from Jira webhook settings (X-Hub-Signature header).
# Generate in Jira: Settings → System → WebHooks. Cannot be retrieved later.
# JIRA_WEBHOOK_SECRET=

# --- Local webhook (ngrok free static domain) ---
# One-time setup: https://dashboard.ngrok.com/domains → claim your free domain.
# Then: ngrok config add-authtoken <token>  (from https://dashboard.ngrok.com/get-started/your-authtoken)
WEBHOOK_PORT=8000
WEBHOOK_PUBLIC_URL=https://it-help-desk-agent.ngrok-free.app
# Paste into Jira WebHooks: ${WEBHOOK_PUBLIC_URL}/webhook/jira
